# ==============================================================================
# 评估报告自动化填充 - 模块化长文本库 (V13.0 - 前后端一体化测算依据管理落地版)
# ==============================================================================
# 使用说明：
# 1. 每一个标黄的大段落都拥有一套【完全独立的文案控制方案】和【专属的业务判定依据】。
# 2. 【第三部分】已改为“素材库 + 后端 builder + 前端大文本微调”模式。
#    - 第三部分核心素材维护在 02_Process/ownership_material_library.json。
#    - Word 模板仅保留最终占位符，不再承担复杂权属情形判断。
#    - 后端 ownership_builder.py 负责把素材库、依据文件清单和表单字段组合成可修改草稿。
# ==============================================================================

# ==============================================================================
# 【大段落方案一】估价对象历史权源及权属变更说明 (第三部分素材库架构)
#  - 场景类型 (land_status_type)：
#     * new_grant: 新出让未登记场景 (典型地块：湖南紫金新材料产业集聚区)
#     * historical_unregistered: 非新出让且因历史遗留未登记场景 (典型地块：皮革厂家属楼)
#     * registered: 常规已登记场景 (有正式土地证/不动产权证，登记清晰)
# ==============================================================================
ownership_history_scheme:
  # 第三部分素材库入口：02_Process/ownership_material_library.json
  description: "第三部分叙事骨架由 ownership_material_library.json 维护，ownership_builder.py 读取后生成 land_registration_desc、land_right_desc、land_use_status_desc 三个最终正文草稿。"


# ==============================================================================
# 【大段落方案二】①公示地价系数修正法 - 适用性说明段落 (公示地价系数修正法底下的段落)
#  - 判定依据：估价对象所处区域的【城区土地级别】与最新政策文件 (land_level_type)
# ==============================================================================
valuation_method_applicability_scheme:
  # 方案分支 A：属于城区居住用地三级用地范围 (对应住宅三级基准地价)
  residential_level_3: >
    评估宗地位于{{ land_location }}，属于{{ local_county }}城区居住用地三级用地范围，根据《{{ base_price_doc_authority }}关于更新城镇基准地价标准和等级的通知》（{{ base_price_doc_no }}，{{ base_price_publish_date }}），{{ local_county }}城镇基准地价从{{ base_price_publish_date }}起公布执行，基准日为{{ base_price_base_date }}，估价对象位于基准地价覆盖范围内，有科学的城镇住宅用地修正体系可以采用，故采用公示地价系数修正法作为评估方法。

  # 方案分支 B：属于城区居住用地二级用地范围 (对应住宅二级基准地价)
  residential_level_2: >
    评估宗地位于{{ land_location }}，属于{{ local_county }}城区居住用地二级用地范围，根据《{{ base_price_doc_authority }}关于更新城镇基准地价标准和等级的通知》（{{ base_price_doc_no }}，{{ base_price_publish_date }}），{{ local_county }}城镇基准地价从{{ base_price_publish_date }}起公布执行，基准日为{{ base_price_base_date }}，估价对象位于基准地价覆盖范围内，有科学的城镇住宅用地修正体系可以采用，故采用公示地价系数修正法作为评估方法。

  # 方案分支 C：基准地价过期场景（所有政策依据均由表单/配置注入，避免县市硬编码）
  base_land_price_expired: >
    {{ local_county }}城镇基准地价的颁布实施时间为{{ base_price_publish_date }}，城区基准地价估价基准日为{{ base_price_base_date }}，批准文号为{{ base_price_doc_no }}，文件名称为{{ base_price_doc_name }}，批准机关为{{ base_price_doc_authority }}。本次估价期日为{{ valuation_date }}，{{ base_price_elapsed_clause }}。根据{{ base_price_rule_doc_name }}（{{ base_price_rule_doc_no }}）：“城镇基准地价每{{ base_price_update_cycle_years_text }}年应全面更新一次，超过{{ base_price_disable_threshold_years_text }}年未全面更新的，不得作为确定出让最低价标准的依据，不得作为宗地评估基准地价系数修正法的依据。”因此不选择基准地价系数修正法。

  # 方案分支 D：商业服务业用途基准地价或市场资料适配
  commercial_level: >
    评估宗地位于{{ land_location }}，设定用途为{{ land_usage_short }}。商业服务业用地的地价水平受临街条件、商业服务业集聚度、人流车流、可达性及周边经营性物业市场状况影响较大，本次评估结合估价对象所在区域的商业服务业用地市场资料、规划利用条件及可比交易情况综合判断评估方法适用性。

  # 方案分支 E：公共管理与公共服务用地适用性长方案
  public_level: >
    评估宗地位于{{ land_location }}，设定用途为{{ land_usage_short }}。公共管理与公共服务用地通常具有公益属性，同类土地市场交易实例及租赁收益实例较少，本次评估结合估价对象所在区域的土地利用现状、公共服务设施规划布局及政府相关产业价格政策，综合判定评估方法在估价对象条件下的适用性。


# ==============================================================================
# 【大段落方案三】1、地价的确定 - 依据及加权说明段落 (地价的确定底下的段落)
#  - 判定依据：所采用的【评估方法组合】及价格加权调和规则 (method_combination_type)
# ==============================================================================
final_price_determination_scheme:
  # 方案分支 A：收益还原法 + 基准地价系数修正法 (双方法加权平均调和)
  weight_average_method: >
    综合分析，两种方法评估的结果内涵一致，考虑到收益还原法是根据估价对象周边类似物业客观租金水平，与基准地价系数修正法测算结果相比更能反映估价对象地价水平的现势性和差异性，根据项目特点，综合考虑估价对象所在区域的地价水平，确定以收益还原法测算结果与基准地价系数修正法测算结果的加权平均值（取整）作为最终结果较为合理。

  # 方案分支 B：基准地价系数修正法 + 市场比较法 (双方法加权)
  market_and_base_weight: >
    综合分析，由于估价对象所在区域近期存在多起类似住宅用地的成交实例，市场比较法测算结果极具市场参考价值；同时基准地价系数修正法反映了区域整体地价基准。故本次评估确定以市场比较法测算结果与基准地价系数修正法测算结果的算术平均值作为最终确定价格。

  # 方案分支 C：仅采用基准地价系数修正法 (单一方法主导)
  single_method_base: >
    综合分析，考虑到估价对象所在区域交易实例稀少，不具备市场比较条件；且无租赁实例，不适宜收益还原法。本次评估以基准地价系数修正法测算结果作为地价最终确定的合理依据。

  # 方案分支 D：仅采用剩余法 (剩余法唯一主导，适用于住宅报告)
  residential_residual_only: >
    通过对当地土地市场和土地价格的分析，并结合方法可靠性、资料完备性及项目特点，综合考虑宗地所在区域的地价水平，确定以剩余法的评估结果作为本次评估的最终结果。

  # 方案分支 E：成本逼近法 + 市场比较法 (双方法简单算术平均，适用于工业报告)
  industrial_cost_and_market_average: >
    综上所述，通过对当地土地市场、土地价格水平和两种方法可靠性的综合分析，根据项目特点，综合考虑宗地所在区域的地价水平，确定以成本逼近法和市场比较法评估结果的简单算术平均值[成本逼近法×50%+市场比较法×50%]作为本次评估的最终结果。

  # 方案分支 F：商业服务业用途市场与收益逻辑
  commercial_market_income: >
    综合分析，商业服务业用地价格通常与区位可达性、商业集聚度、客流条件及未来经营收益预期密切相关。结合估价对象所在区域经营性用地市场状况、可比交易资料及本次采用方法的测算结果，确定以所采用评估方法结果综合分析后的价格作为本次评估的最终结果。

  # 方案分支 G：公共管理与公共服务用途的社会成本重置与加权确价逻辑
  public_service_cost_average: >
    综合分析，公共管理与公共服务用地主要以保障社会公益配套和满足基础重置建设为核心导向。本次评估结合社会公共效益定位、项目成本重置核算以及本次所采用方法的测算结果，经综合研判分析，确定最终地面价格。


# ==============================================================================
# 【大段落方案四】土地开发程度与“五通一平”实际情况详细说明 (模板高亮 #40 / #77)
#  - 判定依据：宗地红线内外【基础设施开发实际状态】(infrastructure_type)
# ==============================================================================
infrastructure_detail_scheme:
  # 方案分支 A：宗地红线外“五通”红线内“场地平整” (通路、通电、供水、排水、通讯) - 住宅顺序
  five_通_residential: >
    基础设施条件：估价对象土地实际开发程度为宗地红线外“五通”（即通路、通电、供水、排水、通讯），红线内场地平整无建筑物，详见下表。

  # 方案分支 B：宗地红线外“五通”红线内“场地平整” (通路、通电、通讯、供水、排水) - 工业顺序
  five_通_industrial: >
    基础设施条件：估价对象土地实际开发程度为宗地红线外“五通”（即通路、通电、通讯、供水、排水），红线内场地平整无建筑物，详见下表。

  # 方案分支 C：商业服务业用途基础设施顺序
  five_通_commercial: >
    基础设施条件：估价对象土地实际开发程度为宗地红线外“五通”（即通路、通电、供水、排水、通讯），红线内开发状态以委托方提供资料及现场勘查结果为准，详见下表。

  # 方案分支 D：公共管理与公共服务用途基础设施开发程度
  five_通_public: >
    基础设施条件：估价对象土地实际开发程度为宗地红线外“五通”（即通路、通电、供水、排水、通讯），红线内场地达到现状公用设施建设及社会公益属性要求，详见下表。

  # 方案分支 D：宗地红线外“三通”红线内“场地平整” (通路、通电、供水)
  three_通: >
    基础设施条件：估价对象土地实际开发程度为宗地红线外“三通”（即通路、通电、给水），红线内场地平整。


# ==============================================================================
# 【大段落方案五】各评估方法采用的客观选用理由 (Adopt Reasons for 5 Methods)
# ==============================================================================
valuation_method_adopt_reasons:
  use_cost_approx:
    residential: >
      成本逼近法是以开发土地所耗费的各项客观费用之和为主要依据，再加上一定的利润、利息、应缴纳的税金和土地增值收益来确定土地价格的方法。考虑到估价对象所在区域有土地征收案例，政府公布了征地有关文件与补偿标准，可测算土地取得成本，且红线内外开发及成片前期投入数据充实，故选择成本逼近法作为土地评估方法之一。
    industrial: >
      成本逼近法是以开发土地所耗费的各项客观费用之和为主要依据，再加上一定的利润、利息、应缴纳的税金和土地增值收益来确定土地价格的方法，尤其对新开发土地，可采用成本逼近法进行评估。考虑到估价对象所在区域有类似征地案例，能够通过征地案例调查分析，对各项土地取得成本进行量化得出土地价格。根据{{ county_name or local_county or '当地' }}自然资源和规划局土地利用科提出的意见，本次评估采用成本逼近法作为评估方法之一。
    commercial: >
      成本逼近法是以开发土地所耗费的各项客观费用之和为主要依据，再加上一定的利润、利息、应缴纳的税金和土地增值收益来确定土地价格的方法。对于商业服务业用地，在可合理取得区域成片开发投入及相关土地规费时，可以通过成本逼近法计算宗地重置成本，作为评估的合理核校路径，故采用成本逼近法作为评估方法之一。
    public: >
      成本逼近法是以开发土地所耗费的各项客观费用之和为主要依据，再加上一定的利润、利息、应缴纳的税金和土地增值收益来确定土地价格的方法。公共管理与公共服务用地具有公益属性，利用现状或规划受限，成本逼近法能够客观反映土地取得及前期各项大市政配套设施的实际重置投入，故采用成本逼近法作为方法之一。
    other: >
      成本逼近法是以开发土地所耗费的各项客观费用之和为主要依据，再加上一定的利润、利息、应缴纳的税金和土地增值收益来确定土地价格的方法。在各项土地取得及前期配套费客观充实的情况下，能够科学核算物理重置成本，故采用成本逼近法进行评估。

  use_market_comp:
    residential: >
      估价对象位于{{ county_name or local_county or '当地' }}城区，土地规划用途为住宅用地，宗地所在区域周边住宅市场活跃度高，有充足的同类型土地市场成交案例，可以选择到与估价对象相类似的近期已经发生交易的纯土地市场交易案例，通过对比较案例期日、用途、年期、交易方式、区域因素、个别因素等修正，得出估价对象的比准土地价格，适宜选用市场比较法进行评估。
    industrial: >
      估价对象位于{{ county_name or local_county or '当地' }}集聚区，土地规划用途为工业用地，宗地所在区域周边有同类型土地市场成交案例，可以选择到与估价对象相类似的近期已经发生交易的纯土地市场交易案例，通过对比较案例考虑期日、用途、年期、交易方式、区域因素、个别因素等影响因素的修正，得出估价对象的土地价格，适宜选用市场比较法进行评估。
    commercial: >
      估价对象规划用途为商业服务业用地，若周边同类商业服务业用地交易或流转案例具有可采性，市场比较法能够通过区域和个别因素修正测算地价，故可选用市场比较法进行评估。
    public: >
      在估价对象所处区域能够收集到同类公共服务设施或公用土地交易实例时，市场比较法能够基于替代原理，通过横向修正真实反映该用途地块在公开市场上的公允价值，故采用市场比较法进行评估。
    other: >
      在同一供求圈或相近区域内能够收集到符合要求的三宗及以上类似产权交易案例时，采用市场比较法进行修正，能最直接灵敏地反映产权市场的价值实态，故选用该方法。

  use_income_cap:
    residential: >
      由于估价对象地上房屋建筑物有潜在收益，所在区域内同类型用房租赁情况较多，不动产总收益较易确定，且未来收益与风险资本化还原率能够客观量化，故可采用收益还原法作为评估方法之一。
    industrial: >
      若估价对象周边工业厂房、配套设施的公开出租实例较多，或能通过工业资产的出租收益或通过对工业企业标准厂房生产运营总收益进行科学剥离，合理核算出土地纯收益。通过合理折现，能真实反映土地在工业运营周期内的资产收益潜能，故选用收益还原法作为评估方法之一。
    commercial: >
      估价对象设定用途为商业服务业用地，如地上房屋建筑物具有经营或租金收益，且同类型商业用房租赁、经营资料具有可采性，可通过收益资本化路径反映其收益价格，故可选用收益还原法作为评估方法之一。
    public: >
      针对实行市场化收费、能独立核算纯收益的公共服务设施（如营利性医院、私立学校、收费停车场、文体场馆等），其持续稳定的运营收入及相关开发成本能合理量化，可采用收益还原法测算反映其在特定营利许可条件下的资产还原潜力，故采用收益还原法作为方法之一。
    other: >
      在估价对象存在稳定、可持续的纯收益流，且相关还原率和收益年期参数能够客观且科学核算的前提下，选用收益还原法最能反映资产资本化的核心本质，故选用该方法。

  use_benchmark_corr:
    residential: >
      评估宗地属于{{ county_name or local_county or '当地' }}城区居住用地范围，根据现行有效的城镇基准地价，估价对象位于基准地价覆盖范围内，有科学的城镇住宅用地修正体系可以采用，能够保证地价评估符合当地政府宏观地价政策，维护地价的稳定性，故采用公示地价系数修正法（基准地价系数修正法）作为评估方法之一。
    industrial: >
      评估宗地属于{{ county_name or local_county or '当地' }}城区工业用地范围，有对应土地级别的工业基准地价标准和修正系数表。该方法有利于从宏观及法定地价等级上把握工业用地的平均地价水平，故采用基准地价系数修正法作为评估方法之一。
    commercial: >
      评估宗地处于{{ county_name or local_county or '当地' }}商业基准地价覆盖范围内，商业服务业用地级别与临街因素修正体系完备，能够合理体现商业区位价值等级和政策指导地价水平，具有很好的政策连贯性，故选用基准地价系数修正法作为方法之一。
    public: >
      评估宗地处于当地城镇基准地价覆盖范围内，公共管理与公共服务用地级别划分明确，且有现行有效的基准地价修正系数规则，有利于贯彻法定价格政策，故采用基准地价系数修正法进行评估。
    other: >
      估价对象处于基准地价覆盖区内，且规划用途具有对应级别和修正规则，能有效利用政府法定公示成果进行因素修正以反映指导价格水平，故选用该方法。

  use_residual:
    residential: >
      由于估价对象地上房屋建筑物及配套设施可以进行开发或再开发，其规划利用条件和开发设计指标明确。通过对开发完成后的房地产总价值的客观预测，并科学扣除追加的工程建设成本、利税及合理开发利润，能够以残余要素估价原理，科学测算出土地要素的剩余开发价值，故选用剩余法进行评估。
    industrial: >
      估价对象虽然为工业待开发项目，但若其建成后的厂房与配套销售价格或预期价值可以通过市场比较法合理确定，并且追加的建设成本和开发利税资料清晰，亦可选用剩余法科学核算潜在地价，故选用该方法之一。
    commercial: >
      估价对象为商业服务业待开发地块，规划设计指标明确，且商业追加开发的预期售价、租金水平、建设成本和合理利润能够合理预测时，可通过剥离后期追加成本测算土地剩余价格，故选用剩余法进行评估。
    public: >
      在估价对象存在明确的代建开发协议、公共开发利用规划，且建成后的重置总价值与追加建造成本、利税参数能够客观确定的前提下，可通过剩余法作为开发辅助核算，故选用该方法进行评估。
    other: >
      在估价对象规划条件明确，且开发完成后不动产整体交易价值与后期追加的工程开发及各项利税成本能够合理量化且预测的前提下，选用剩余法较能反映资产潜在的开发残余价值，故选用该方法进行评估。


# ==============================================================================
# 【大段落方案六】各评估方法未启用的排除理由 (Exclude Reasons for 5 Methods)
# ==============================================================================
valuation_method_exclude_reasons:
  use_market_comp: >
    不选择市场比较法：根据地产市场调查，估价对象所处区域同一供需圈内近期类似的国有土地出让及转让成交案例极少（可比案例仅有{{ comparable_case_count or '______' }}个，少于3个），且交易目的和宏观条件与设定用途差异显著，无法收集到足够数量且具备高度可比性的案例，难以建立可靠的价格比较基础，故不选用市场比较法。

  use_income_cap: >
    {% if not has_stable_income_data %}不选择收益还原法：由于该区域同类物业近期缺乏公开、活跃的租赁交易市场，无法收集到充足、客观且具备代表性的历史租金收益与长期稳定的运营成本数据，土地纯收益及资本化还原率等关键还原参数难以客观且准确测算，难以客观预测未来的预期土地纯收益，故不选用收益还原法。{% else %}不选择收益还原法：尽管周边有零星收益性项目，但由于估价对象现状为待开发建设用地，其土地与其上附着物的未来收益以及企业经营收益难以合理且客观地剥离，土地收益的测算存在较大的不确定性，故本次评估不选用收益还原法。{% endif %}

  use_cost_approx: >
    {% if not cost_data_reliable %}不选择成本逼近法：估价对象设定用途为{{ land_usage_short or '设定用途' }}，本项目缺乏可直接采信的土地取得成本、征拆补偿、开发配套费用或相关税费利润资料，原始或重置成本难以充分反映估价期日的市场价值，不符合成本法测算的资料基础条件，故不选用成本逼近法。{% else %}不选择成本逼近法：估价对象设定用途为{{ land_usage_short or '设定用途' }}，本项目虽能粗略估算土地取得及开发税费，但由于估价对象当前价值受区位交通、市场供求、规划利用条件等因素影响较大，原始重置成本难以充分反映估价期日的客观合理市场价值，故本次评估不选用成本逼近法。{% endif %}

  use_residual: >
    {% if not development_value_measurable %}不选择剩余法（增值收益扣减法）：剩余法主要适用于具有明显投资开发或再开发潜力的土地估价。由于估价对象周边待开发熟地交易案例及建成后商品化不动产市场成交信息较少，难以合理且客观地预测估价对象建成后商品房的客观总价值，无法准确扣除后续开发应追加的工程建造成本及合理利润，缺乏开展剩余法测算的数据支撑，故不选用剩余法进行评估。{% else %}不选择剩余法（增值收益扣减法）：剩余法适用于投资开发潜力显著的宗地评估。估价对象周边待开发熟地交易案例及建成后商品化不动产成交案例较少，难以通过市场比准合理预测并确定建成后的房地产客观总价值；进而无法准确剥离并扣除开发项目整体追加的工程建造成本、客观开发利润及相关利税以求取纯土地价格余额，不符合剩余法剥离的前提条件，因而不选用剩余法进行评估。{% endif %}

  use_benchmark_corr: >
    {% if is_base_price_expired or base_price_is_expired %}不选择公示地价修正法（基准地价系数修正法）：{{ county_name or local_county or '当地' }}城镇基准地价的颁布实施时间为{{ base_price_publish_date or '______' }}，城区基准地价估价基准日为{{ base_price_base_date or '______' }}，批准文号为{{ base_price_doc_no or '______' }}，文件名称为{{ base_price_doc_name or '______' }}，批准机关为{{ base_price_doc_authority or '______' }}，本次估价期日为{{ valuation_date or '______' }}，{{ base_price_elapsed_clause or '该基准地价已过期失效。' }}{% else %}不选择公示地价修正法：虽然估价对象处于基准地价覆盖范围内，但由于其特定微观规划利用条件、地块形状与个性化利用约束已大幅超出基准地价修正因素说明体系的常规覆盖范围；或由于区域近期发生了剧烈的微观市场化价格异动，利用宏观指导地价修正易产生均值化偏差。为了防范政策地价与个别属性失真，本次已选用了针对性更强的微观方法，故不选择公示地价系数修正法。{% endif %}


# ==============================================================================
# 【大段落方案七】成本逼近法计算过程前置大段话术 (V13.0 素材库与前端联合大一统)
# ==============================================================================
cost_approx_process_intro: >
  估价对象位于{{ land_location }}，根据《{{ gov_approval_name or '政府批复文件' }}》（{{ gov_approval_no or '批复文号' }}，{{ gov_approval_date or '批复日期' }}），评估宗地征收地类为{{ original_land_owner_desc or '______' }}，此次采用成本逼近法评估待估宗地地价时，估价期日被征用的土地为{{ original_land_owner_desc or '______' }}。
  估价对象的估价期日为{{ valuation_date or '______' }}，本次成本逼近法测算以{{ valuation_basis_docs_rendered or '【请填写土地评估计算过程依据】' }}及估价对象所在地区现行有效的相关配套政策文件为依据。根据成本逼近法测算地价的步骤，其各项费用如下：
