function countTop(){
	var windowWidth = (document.documentElement||document.body).scrollWidth;
	topPositionX = windowWidth/2 + dposition;
	//console.log(topPositionX);
	var tobj = document.getElementById("topSystemBtn_id");
	tobj.style.left = topPositionX+"px";
	var obj = document.getElementById("div_topSystem_id");
	obj.style.right = (windowWidth - getCoords(tobj).left - tobj.offsetWidth) + "px";
	obj.style.top = (tobj.offsetHeight) + "px";
	var lobj = document.getElementById("comm_topLink_id");
	lobj.style.right = (windowWidth - tobj.offsetLeft + 20) + "px";
        //lobj.style.left = (topPositionX - lobj.offsetWidth - 15) + "px";
}
function countMid(){
	try{
	var mbtn = document.getElementById("midSystemBtn_id");
	var mobj = document.getElementById("div_midSystem_id");
	mobj.style.left = ( getCoords(mbtn).left ) + "px";
	mobj.style.top = ( getCoords(mbtn).top + mbtn.offsetHeight) + "px";
	}catch(o){}
}
function countPosition(){
	countTop();
	countMid();
}


