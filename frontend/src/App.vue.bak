  other_special_notes_ref: { value: '第十一部分  其他需要说明的事项', origin: 'manual', is_dirty: false },

  // 3. ⚖️ 第四章：评估方法选择与加权确价
  use_cost_approx: { value: true, origin: 'manual', is_dirty: false },
  use_market_comp: { value: true, origin: 'manual', is_dirty: false },
