<template>
  <div :class="['app-wrapper', { 'light-theme': isLightTheme }]">
    
    <!-- 🧭 顶部导航栏 -->
    <header class="top-navbar">
      <div class="brand-section">
        <span class="brand-logo">📊</span>
        <h1 class="brand-title">双轨制可视化评估报告生成平台</h1>
      </div>
      
      <div class="controls-section">
        <!-- 💡 一键高对比度浅色/暗色切换，防眼部疲劳 -->
        <button class="icon-btn" @click="toggleTheme">
          <span v-if="isLightTheme">🌙 护眼深色</span>
          <span v-else>☀️ 冷白高反差</span>
        </button>
        
        <!-- 一键 A4 高保真渲染预览 -->
        <button class="icon-btn primary" @click="handleRenderReport" :disabled="isLoading">
          <span>📄 高保真 A4 渲染</span>
        </button>
      </div>
    </header>
    
    <!-- 🖥️ 双栏主视窗 -->
    <main class="main-viewport" 
          @dragover.prevent="handleDragOver" 
          @dragleave.prevent="handleDragLeave" 
          @drop.prevent="handleFileDrop">
      
      <!-- Excel 拖拽覆盖遮罩 -->
      <div v-if="isDragging" class="excel-drag-overlay">
        <div class="drag-icon">📥</div>
        <h2>请释放鼠标，立即一键解析测算表</h2>
        <p>系统将为您毫秒级回填 100% 对齐契约的指标</p>
      </div>
      
      <!-- ==============================================================================
           左侧：高密度表单填报区
           ============================================================================== -->
      <section class="left-panel">
        <div class="scroll-form-container">
          
          <!-- 📊 快捷数据源状态栏 -->
          <div class="fold-card" style="border-color: var(--accent);">
            <div class="card-body" style="grid-template-columns: 1fr; gap: 8px; padding: 12px;">
              <div style="font-size: 12px; font-weight: 700; color: var(--accent);">
                📂 智能双轨填报工作流引导：
              </div>
              <div style="font-size: 11px; color: var(--text-secondary); line-height: 1.5;">
                1. 拖拽 Excel 测算表至本窗口任意位置以自动解析回填；<br>
                2. 复制不动产权证或规划函 OCR 文本至底部终端一键捕获；<br>
                3. 手动微调淡蓝色高亮字段，主权秒级回归人工。
              </div>
              <div v-if="excelMetadata.name" style="margin-top: 4px; padding: 6px; background: rgba(0,0,0,0.2); border-radius: 4px; font-size: 11px;">
                <span style="color: var(--success);">✔ 已加载测算表:</span> {{ excelMetadata.name }} <br>
                <span style="color: var(--text-secondary);">指纹MD5:</span> <code style="color: var(--accent);">{{ excelMetadata.md5.substring(0, 12) }}...</code>
              </div>
            </div>
          </div>
          
          <!-- 卡片一：地理区划与报告基础信息 -->
          <!-- 第一章：报告基本信息与地理区划 -->
          <div :class="['fold-card', { 'is-collapsed': collapsed.p1 }]">
            <div class="card-header" @click="collapsed.p1 = !collapsed.p1">
              <span class="card-title">📁 第一章：报告基本信息与地理区划</span>
              <span class="card-toggle-icon">▼</span>
            </div>
            <div class="card-body">
              <div class="form-item full-width" style="display: flex; gap: 16px; margin-bottom: 12px;">
                <div style="flex: 1;">
                  <label class="form-label">出让/评估目的模式（ transfer_purpose_mode ）</label>
                  <select v-model="form.transfer_purpose_mode.value" @change="onTransferPurposeModeChange" class="field-input">
                    <option value="拟挂牌出让">拟挂牌出让</option>
                    <option value="办理土地使用权出让手续">办理土地使用权出让手续</option>
                    <option value="其他">其他（自定义）</option>
                  </select>
                </div>
                <div style="flex: 2;" v-if="form.transfer_purpose_mode.value === '其他'">
                  <label class="form-label">自定义出让/评估目的（ transfer_purpose ）</label>
                  <input type="text" v-model="form.transfer_purpose.value" @input="onFieldInput('transfer_purpose')" class="field-input" placeholder="请输入自定义出让/评估目的..." />
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">估价项目名称（ project_name ）</label>
                <div class="input-wrapper" style="display: flex; flex-direction: column; gap: 8px; width: 100%;">
                  <div style="display: flex; gap: 8px; width: 100%; align-items: stretch;">
                    <textarea v-model="form.project_name.value" 
                              :class="['field-input', getInputClass('project_name')]" 
                              readonly 
                              style="background-color: rgba(0,0,0,0.1); flex: 1; cursor: not-allowed; resize: none; min-height: 50px; line-height: 1.4; padding: 8px; width: 100%;" 
                              title="由各字段自动拼接生成，不可直接编辑"></textarea>
                    <div style="display: flex; flex-direction: column; gap: 4px;">
                      <button @click.prevent="unlockProjectNameSuffix" class="icon-btn" style="white-space: nowrap; font-size: 12px; height: 28px;" title="修改默认后缀">修改后缀</button>
                      <span v-if="showBadge('project_name')" :class="['origin-badge', getBadgeClass('project_name')]" style="align-self: center;">
                        {{ getBadgeText('project_name') }}
                      </span>
                    </div>
                  </div>
                  <!-- 隐藏的后缀输入框，如果解锁则显示 -->
                  <div v-if="isSuffixUnlocked">
                    <label class="form-label">修改后缀（ project_name_suffix ）</label>
                    <input type="text" v-model="form.project_name_suffix.value" @input="onFieldInput('project_name_suffix')" class="field-input" />
                  </div>
                </div>
              </div>
              <div class="form-item full-width">
                <label class="form-label">委托人名称（ client_name ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.client_name.value" @input="onFieldInput('client_name')" 
                         :class="['field-input', getInputClass('client_name')]" />
                  <span v-if="showBadge('client_name')" :class="['origin-badge', getBadgeClass('client_name')]">
                    {{ getBadgeText('client_name') }}
                  </span>
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">受托估价机构（ appraisal_org ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.appraisal_org.value" @input="onFieldInput('appraisal_org')" 
                         :class="['field-input', getInputClass('appraisal_org')]" />
                  <span v-if="showBadge('appraisal_org')" :class="['origin-badge', getBadgeClass('appraisal_org')]">
                    {{ getBadgeText('appraisal_org') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">土地使用者（ land_user ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.land_user.value" @input="onFieldInput('land_user')" 
                         :class="['field-input', getInputClass('land_user')]" />
                  <span v-if="showBadge('land_user')" :class="['origin-badge', getBadgeClass('land_user')]">
                    {{ getBadgeText('land_user') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">评估报告编号（ report_no ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.report_no.value" @input="onFieldInput('report_no')" 
                         :class="['field-input', getInputClass('report_no')]" />
                  <span v-if="showBadge('report_no')" :class="['origin-badge', getBadgeClass('report_no')]">
                    {{ getBadgeText('report_no') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">报告出具日期（ report_date ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.report_date.value" @input="onFieldInput('report_date')" 
                         :class="['field-input', getInputClass('report_date')]" />
                  <span v-if="showBadge('report_date')" :class="['origin-badge', getBadgeClass('report_date')]">
                    {{ getBadgeText('report_date') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">估价期日（ valuation_date ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.valuation_date.value" @input="onFieldInput('valuation_date')" 
                         :class="['field-input', getInputClass('valuation_date')]" />
                  <span v-if="showBadge('valuation_date')" :class="['origin-badge', getBadgeClass('valuation_date')]">
                    {{ getBadgeText('valuation_date') }}
                  </span>
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">现场勘查与工作日期范围（ valuation_work_date ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.valuation_work_date.value" @input="onFieldInput('valuation_work_date')" 
                         :class="['field-input', getInputClass('valuation_work_date')]" />
                  <span v-if="showBadge('valuation_work_date')" :class="['origin-badge', getBadgeClass('valuation_work_date')]">
                    {{ getBadgeText('valuation_work_date') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">委托方统一社会信用代码（ client_org_code ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.client_org_code.value" @input="onFieldInput('client_org_code')" 
                         :class="['field-input', getInputClass('client_org_code')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">委托方负责人（ client_principal ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.client_principal.value" @input="onFieldInput('client_principal')" 
                         :class="['field-input', getInputClass('client_principal')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">委托方机构性质（ client_org_type ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.client_org_type.value" @input="onFieldInput('client_org_type')" 
                         :class="['field-input', getInputClass('client_org_type')]" />
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">委托方机构地址（ client_address ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.client_address.value" @input="onFieldInput('client_address')" 
                         :class="['field-input', getInputClass('client_address')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">委托方联系人（ client_contact ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.client_contact.value" @input="onFieldInput('client_contact')" 
                         :class="['field-input', getInputClass('client_contact')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">委托方联系电话（ client_phone ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.client_phone.value" @input="onFieldInput('client_phone')" 
                         :class="['field-input', getInputClass('client_phone')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">委托方邮编（ client_postcode ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.client_postcode.value" @input="onFieldInput('client_postcode')" 
                         :class="['field-input', getInputClass('client_postcode')]" />
                </div>
              </div>
            </div>
          </div>


          <!-- 第二章：土地利用条件与规划限制指标 -->
          <div :class="['fold-card', { 'is-collapsed': collapsed.p2 }]">
            <div class="card-header" @click="collapsed.p2 = !collapsed.p2">
              <span class="card-title">📐 第二章：土地利用条件与规划限制指标</span>
              <span class="card-toggle-icon">▼</span>
            </div>
            <div class="card-body">
              <div class="form-item full-width">
                <label class="form-label">估价对象坐落位置（简称）（ land_location ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.land_location.value" @input="onFieldInput('land_location')" 
                         :class="['field-input', getInputClass('land_location')]" />
                  <span v-if="showBadge('land_location')" :class="['origin-badge', getBadgeClass('land_location')]">
                    {{ getBadgeText('land_location') }}
                  </span>
                </div>
              </div>
              <div class="form-item full-width">
                <label class="form-label">地块编号（ land_plot_number ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.land_plot_number.value" @input="onFieldInput('land_plot_number')" 
                         :class="['field-input', getInputClass('land_plot_number')]" placeholder="如：（2025018号地块）" />
                  <span v-if="showBadge('land_plot_number')" :class="['origin-badge', getBadgeClass('land_plot_number')]">
                    {{ getBadgeText('land_plot_number') }}
                  </span>
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">估价对象位置全称（ land_location_full ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.land_location_full.value" readonly style="background-color: rgba(0,0,0,0.1); cursor: not-allowed;" title="由简称与编号自动拼接生成" class="field-input" />
                  <span v-if="showBadge('land_location_full')" :class="['origin-badge', getBadgeClass('land_location_full')]">
                    {{ getBadgeText('land_location_full') }}
                  </span>
                </div>
              </div>
              <div class="form-item">
                <label class="form-label">估价所属县市简称（ county_name ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.county_name.value" @input="onFieldInput('county_name')" 
                         :class="['field-input', getInputClass('county_name')]" />
                  <span v-if="showBadge('county_name')" :class="['origin-badge', getBadgeClass('county_name')]">
                    {{ getBadgeText('county_name') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">技术报告编号（ technical_report_no ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.technical_report_no.value" @input="onFieldInput('technical_report_no')" 
                         :class="['field-input', getInputClass('technical_report_no')]" />
                  <span v-if="showBadge('technical_report_no')" :class="['origin-badge', getBadgeClass('technical_report_no')]">
                    {{ getBadgeText('technical_report_no') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">宗地数量（ parcel_count ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.parcel_count.value" @input="onFieldInput('parcel_count')" 
                         :class="['field-input', getInputClass('parcel_count')]" />
                  <span v-if="showBadge('parcel_count')" :class="['origin-badge', getBadgeClass('parcel_count')]">
                    {{ getBadgeText('parcel_count') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">分摊使用权面积（㎡）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.land_area.value" @input="onFieldInput('land_area')" 
                         :class="['field-input', getInputClass('land_area')]" />
                  <span v-if="showBadge('land_area')" :class="['origin-badge', getBadgeClass('land_area')]">
                    {{ getBadgeText('land_area') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">建筑总面积（㎡）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.building_area.value" @input="onFieldInput('building_area')" 
                         :class="['field-input', getInputClass('building_area')]" />
                  <span v-if="showBadge('building_area')" :class="['origin-badge', getBadgeClass('building_area')]">
                    {{ getBadgeText('building_area') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">设定土地用途简称（ land_usage_short ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.land_usage_short.value" @input="onFieldInput('land_usage_short')" 
                         :class="['field-input', getInputClass('land_usage_short')]" />
                  <span v-if="showBadge('land_usage_short')" :class="['origin-badge', getBadgeClass('land_usage_short')]">
                    {{ getBadgeText('land_usage_short') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">设定土地用途全称（ land_usage ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.land_usage.value" @input="onFieldInput('land_usage')" 
                         :class="['field-input', getInputClass('land_usage')]" />
                  <span v-if="showBadge('land_usage')" :class="['origin-badge', getBadgeClass('land_usage')]">
                    {{ getBadgeText('land_usage') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">登记土地用途全称（ land_usage_full ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.land_usage_full.value" @input="onFieldInput('land_usage_full')" 
                         :class="['field-input', getInputClass('land_usage_full')]" />
                  <span v-if="showBadge('land_usage_full')" :class="['origin-badge', getBadgeClass('land_usage_full')]">
                    {{ getBadgeText('land_usage_full') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">使用权类型（ right_type ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.right_type.value" @input="onFieldInput('right_type')" 
                         :class="['field-input', getInputClass('right_type')]" />
                  <span v-if="showBadge('right_type')" :class="['origin-badge', getBadgeClass('right_type')]">
                    {{ getBadgeText('right_type') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">土地使用年限（ land_use_term ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.land_use_term.value" @input="onFieldInput('land_use_term')" 
                         :class="['field-input', getInputClass('land_use_term')]" />
                  <span v-if="showBadge('land_use_term')" :class="['origin-badge', getBadgeClass('land_use_term')]">
                    {{ getBadgeText('land_use_term') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">容积率类型（ plot_ratio_mode ）</label>
                <div class="input-wrapper">
                  <select v-model="form.plot_ratio_mode.value" @change="onPlotRatioInput('plot_ratio_mode')" class="field-input">
                    <option value="range">范围值</option>
                    <option value="fixed">固定值</option>
                  </select>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">{{ form.plot_ratio_mode.value === 'range' ? '设定容积率上限（ plot_ratio ）' : '设定容积率固定值（ plot_ratio ）' }}</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.plot_ratio.value" @input="onPlotRatioInput('plot_ratio')" 
                         :class="['field-input', getInputClass('plot_ratio')]" />
                  <span v-if="showBadge('plot_ratio')" :class="['origin-badge', getBadgeClass('plot_ratio')]">
                    {{ getBadgeText('plot_ratio') }}
                  </span>
                </div>
              </div>

              <div v-if="form.plot_ratio_mode.value === 'range'" class="form-item">
                <label class="form-label">规划容积率下限（ plot_ratio_min ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.plot_ratio_min.value" @input="onPlotRatioInput('plot_ratio_min')" 
                         :class="['field-input', getInputClass('plot_ratio_min')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">报告展示容积率（ plot_ratio_display ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.plot_ratio_display.value" @input="onFieldInput('plot_ratio_display')" 
                         :class="['field-input', getInputClass('plot_ratio_display')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">规划建筑密度下限</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.building_density_min.value" @input="onFieldInput('building_density_min')" 
                         :class="['field-input', getInputClass('building_density_min')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">规划建筑密度上限</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.building_density_max.value" @input="onFieldInput('building_density_max')" 
                         :class="['field-input', getInputClass('building_density_max')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">规划绿地率（ greening_rate ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.greening_rate.value" @input="onFieldInput('greening_rate')" 
                         :class="['field-input', getInputClass('greening_rate')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">规划建筑限高（ building_height_limit ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.building_height_limit.value" @input="onFieldInput('building_height_limit')" 
                         :class="['field-input', getInputClass('building_height_limit')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">设定利用条件类型（ valuation_condition_type ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.valuation_condition_type.value" @input="onFieldInput('valuation_condition_type')" 
                         :class="['field-input', getInputClass('valuation_condition_type')]" />
                  <span v-if="showBadge('valuation_condition_type')" :class="['origin-badge', getBadgeClass('valuation_condition_type')]">
                    {{ getBadgeText('valuation_condition_type') }}
                  </span>
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">实际土地开发程度（ land_development_actual ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.land_development_actual.value" @input="onFieldInput('land_development_actual')" 
                         :class="['field-input', getInputClass('land_development_actual')]" />
                  <span v-if="showBadge('land_development_actual')" :class="['origin-badge', getBadgeClass('land_development_actual')]">
                    {{ getBadgeText('land_development_actual') }}
                  </span>
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">设定土地开发程度（ land_development_set ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.land_development_set.value" @input="onFieldInput('land_development_set')" 
                         :class="['field-input', getInputClass('land_development_set')]" />
                  <span v-if="showBadge('land_development_set')" :class="['origin-badge', getBadgeClass('land_development_set')]">
                    {{ getBadgeText('land_development_set') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">登记土地权利类型（ registered_right_type ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.registered_right_type.value" @input="onFieldInput('registered_right_type')" 
                         :class="['field-input', getInputClass('registered_right_type')]" />
                  <span v-if="showBadge('registered_right_type')" :class="['origin-badge', getBadgeClass('registered_right_type')]">
                    {{ getBadgeText('registered_right_type') }}
                  </span>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">设定土地权利状态描述（ assumed_right_status ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.assumed_right_status.value" @input="onFieldInput('assumed_right_status')" 
                         :class="['field-input', getInputClass('assumed_right_status')]" />
                  <span v-if="showBadge('assumed_right_status')" :class="['origin-badge', getBadgeClass('assumed_right_status')]">
                    {{ getBadgeText('assumed_right_status') }}
                  </span>
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">原始权属登记的依据文书（ registered_proof_docs ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.registered_proof_docs.value" @input="onFieldInput('registered_proof_docs')" 
                         :class="['field-input', getInputClass('registered_proof_docs')]" />
                  <span v-if="showBadge('registered_proof_docs')" :class="['origin-badge', getBadgeClass('registered_proof_docs')]">
                    {{ getBadgeText('registered_proof_docs') }}
                  </span>
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">委托方提供资料清单（ entrusted_source_docs ）</label>
                <div class="input-wrapper">
                  <textarea v-model="form.entrusted_source_docs.value" @input="onFieldInput('entrusted_source_docs')" 
                            rows="4" :class="['field-input', getInputClass('entrusted_source_docs')]" style="height: auto; line-height: 1.5;"></textarea>
                  <span v-if="showBadge('entrusted_source_docs')" :class="['origin-badge', getBadgeClass('entrusted_source_docs')]" style="top: 15px;">
                    {{ getBadgeText('entrusted_source_docs') }}
                  </span>
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">宗地四至状况（ land_boundary_desc ）——【全网页手填一次即可，后端多处动态流转】</label>
                <div class="input-wrapper">
                  <textarea v-model="form.land_boundary_desc.value" @input="onFieldInput('land_boundary_desc')" 
                            rows="2" :class="['field-input', getInputClass('land_boundary_desc')]"></textarea>
                  <span v-if="showBadge('land_boundary_desc')" :class="['origin-badge', getBadgeClass('land_boundary_desc')]" style="top: 10px;">
                    {{ getBadgeText('land_boundary_desc') }}
                  </span>
                </div>
              </div>
            </div>
          </div>

          <!-- 第三章：土地权属及原始证照（智能草稿 + 最终正文） -->
          <div :class="['fold-card', { 'is-collapsed': collapsed.p3 }]" style="border-color: #8b5cf6;">
            <div class="card-header" @click="collapsed.p3 = !collapsed.p3" style="background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(109, 40, 217, 0.15));">
              <span class="card-title" style="color: #c084fc;">📜 第三章：土地权属及原始证照信息</span>
              <span class="card-toggle-icon" style="color: #c084fc;">▼</span>
            </div>
            <div class="card-body">
              <div class="form-item full-width" style="background: rgba(139, 92, 246, 0.08); padding: 10px; border-radius: 6px; border: 1px dashed rgba(139, 92, 246, 0.3);">
                <div style="display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px;">
                  <div>
                    <label class="form-label" style="font-weight: 700; color: #c084fc;">权属情形（ ownership_scenario_type ）</label>
                    <select v-model="form.ownership_scenario_type.value" @change="onOwnershipControlChange('ownership_scenario_type')" class="field-input" style="background: #1e293b; color: #f8fafc; border: 1px solid #475569;">
                      <option value="new_grant">首次出让 / 拟出让</option>
                      <option value="historical_unregistered">历史遗留未登记</option>
                      <option value="registered_complete">已登记</option>
                      <option value="mixed_manual">复杂人工</option>
                    </select>
                  </div>
                  <div>
                    <label class="form-label" style="font-weight: 700; color: #c084fc;">用途话术类型（ asset_use_category ）</label>
                    <select v-model="form.asset_use_category.value" @change="onOwnershipControlChange('asset_use_category')" class="field-input" style="background: #1e293b; color: #f8fafc; border: 1px solid #475569;">
                      <option value="residential">住宅</option>
                      <option value="industrial">工业</option>
                      <option value="commercial">商业服务业</option>
                      <option value="public">公共管理与公共服务</option>
                      <option value="other">其他</option>
                    </select>
                  </div>
                </div>
                <div v-if="form.asset_use_category.value === 'other'" style="margin-top: 10px;">
                  <label class="form-label">其他用途名称（ asset_use_category_other ）</label>
                  <div class="input-wrapper">
                    <input type="text" v-model="form.asset_use_category_other.value" @input="onOwnershipControlChange('asset_use_category_other')" 
                           :class="['field-input', getInputClass('asset_use_category_other')]" placeholder="例如：特殊用地、交通运输用地、仓储物流用地..." />
                  </div>
                </div>
                <div style="display: flex; gap: 12px; align-items: center; margin-top: 10px; flex-wrap: wrap;">
                  <label style="font-size: 12px; display: flex; align-items: center; gap: 6px;">
                    <input type="checkbox" v-model="form.include_registration_risk_note.value" @change="onOwnershipControlChange('include_registration_risk_note')" />
                    追加登记风险提示
                  </label>
                  <button @click.prevent="regenerateOwnershipDraft(true)" class="icon-btn" style="font-size: 12px; height: 28px;">重新生成草稿</button>
                </div>
                <div v-if="form.include_registration_risk_note.value" style="margin-top: 10px;">
                  <label class="form-label">登记风险提示文本（ registration_risk_note ）</label>
                  <div class="input-wrapper">
                    <textarea v-model="form.registration_risk_note.value" @input="onFieldInput('registration_risk_note')" rows="2" :class="['field-input', getInputClass('registration_risk_note')]"></textarea>
                  </div>
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">土地登记状况最终正文（ land_registration_desc ）</label>
                <div class="input-wrapper">
                  <textarea v-model="form.land_registration_desc.value" @input="onFieldInput('land_registration_desc')" 
                            rows="7" :class="['field-input', getInputClass('land_registration_desc')]"></textarea>
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">土地权利状况最终正文（ land_right_desc ）</label>
                <div class="input-wrapper">
                  <textarea v-model="form.land_right_desc.value" @input="onFieldInput('land_right_desc')" 
                            rows="5" :class="['field-input', getInputClass('land_right_desc')]"></textarea>
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">土地利用现状最终正文（ land_use_status_desc ）</label>
                <div class="input-wrapper">
                  <textarea v-model="form.land_use_status_desc.value" @input="onFieldInput('land_use_status_desc')" 
                            rows="5" :class="['field-input', getInputClass('land_use_status_desc')]"></textarea>
                </div>
              </div>

              <details class="form-item full-width" style="border: 1px solid rgba(148,163,184,0.22); border-radius: 6px; padding: 10px;">
                <summary style="cursor: pointer; font-size: 12px; font-weight: 700; color: var(--text-secondary);">附件识别依据与细节字段</summary>
                <div style="display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; margin-top: 12px;">
                  <div>
                    <label class="form-label">政府批复文件名称</label>
                    <input type="text" v-model="form.gov_approval_name.value" @input="onFieldInput('gov_approval_name')" :class="['field-input', getInputClass('gov_approval_name')]" />
                  </div>
                  <div>
                    <label class="form-label">政府批复文号</label>
                    <input type="text" v-model="form.gov_approval_no.value" @input="onFieldInput('gov_approval_no')" :class="['field-input', getInputClass('gov_approval_no')]" />
                  </div>
                  <div>
                    <label class="form-label">政府批复日期</label>
                    <input type="text" v-model="form.gov_approval_date.value" @input="onFieldInput('gov_approval_date')" :class="['field-input', getInputClass('gov_approval_date')]" />
                  </div>
                  <div>
                    <label class="form-label">批准机关</label>
                    <input type="text" v-model="form.approval_authority.value" @input="onFieldInput('approval_authority')" :class="['field-input', getInputClass('approval_authority')]" />
                  </div>
                  <div>
                    <label class="form-label">批准农转用日期</label>
                    <input type="text" v-model="form.approval_transfer_date.value" @input="onFieldInput('approval_transfer_date')" :class="['field-input', getInputClass('approval_transfer_date')]" />
                  </div>
                  <div>
                    <label class="form-label">原土地权属描述</label>
                    <input type="text" v-model="form.original_land_owner_desc.value" @input="onFieldInput('original_land_owner_desc')" :class="['field-input', getInputClass('original_land_owner_desc')]" />
                  </div>
                  <div>
                    <label class="form-label">房屋所有权证名称</label>
                    <input type="text" v-model="form.house_cert_name.value" @input="onFieldInput('house_cert_name')" :class="['field-input', getInputClass('house_cert_name')]" />
                  </div>
                  <div>
                    <label class="form-label">房屋所有权证编号</label>
                    <input type="text" v-model="form.house_cert_no.value" @input="onFieldInput('house_cert_no')" :class="['field-input', getInputClass('house_cert_no')]" />
                  </div>
                  <div>
                    <label class="form-label">面积依据文件名</label>
                    <input type="text" v-model="form.area_docs_desc_name.value" @input="onFieldInput('area_docs_desc_name')" :class="['field-input', getInputClass('area_docs_desc_name')]" />
                  </div>
                  <div>
                    <label class="form-label">房证登记建筑面积</label>
                    <input type="text" v-model="form.registered_house_area.value" @input="onFieldInput('registered_house_area')" :class="['field-input', getInputClass('registered_house_area')]" />
                  </div>
                  <div>
                    <label class="form-label">权属证明文件名</label>
                    <input type="text" v-model="form.proof_doc_name.value" @input="onFieldInput('proof_doc_name')" :class="['field-input', getInputClass('proof_doc_name')]" />
                  </div>
                  <div>
                    <label class="form-label">权属证明日期</label>
                    <input type="text" v-model="form.proof_doc_date.value" @input="onFieldInput('proof_doc_date')" :class="['field-input', getInputClass('proof_doc_date')]" />
                  </div>
                  <div>
                    <label class="form-label">土地使用者身份描述</label>
                    <input type="text" v-model="form.user_identity.value" @input="onFieldInput('user_identity')" :class="['field-input', getInputClass('user_identity')]" />
                  </div>
                  <div>
                    <label class="form-label">购房年份</label>
                    <input type="text" v-model="form.buy_year.value" @input="onFieldInput('buy_year')" :class="['field-input', getInputClass('buy_year')]" />
                  </div>
                  <div>
                    <label class="form-label">房间详细位置坐落</label>
                    <input type="text" v-model="form.room_detail_location.value" @input="onFieldInput('room_detail_location')" :class="['field-input', getInputClass('room_detail_location')]" />
                  </div>
                  <div>
                    <label class="form-label">购房坐落地点描述</label>
                    <input type="text" v-model="form.buy_location_desc.value" @input="onFieldInput('buy_location_desc')" :class="['field-input', getInputClass('buy_location_desc')]" />
                  </div>
                  <div>
                    <label class="form-label">土地使用权证名称</label>
                    <input type="text" v-model="form.land_cert_name.value" @input="onFieldInput('land_cert_name')" :class="['field-input', getInputClass('land_cert_name')]" />
                  </div>
                  <div>
                    <label class="form-label">土地使用权证编号</label>
                    <input type="text" v-model="form.land_cert_no.value" @input="onFieldInput('land_cert_no')" :class="['field-input', getInputClass('land_cert_no')]" />
                  </div>
                  <div style="grid-column: span 2;">
                    <label class="form-label">土地使用权类型描述</label>
                    <input type="text" v-model="form.land_use_type.value" @input="onFieldInput('land_use_type')" :class="['field-input', getInputClass('land_use_type')]" />
                  </div>
                </div>
              </details>
            </div>
          </div>

          <!-- 第四章：评估方法选择与加权确价 -->
          <div :class="['fold-card', { 'is-collapsed': collapsed.p4 }]">
            <div class="card-header" @click="collapsed.p4 = !collapsed.p4">
              <span class="card-title">⚖️ 第四章：评估方法选择与加权确价</span>
              <span class="card-toggle-icon">▼</span>
            </div>
            <div class="card-body">
              <div class="form-item" style="grid-column: span 2; display: flex; flex-direction: row; gap: 16px; align-items: center; background: rgba(0,0,0,0.1); padding: 8px 12px; border-radius: 6px;">
                <label class="form-label" style="font-weight: 700;">采用方法:</label>
                <label style="font-size: 11px; display: flex; align-items: center; gap: 4px;">
                  <input type="checkbox" v-model="form.use_cost_approx.value" @change="onFieldInput('use_cost_approx')" /> 成本逼近
                </label>
                <label style="font-size: 11px; display: flex; align-items: center; gap: 4px;">
                  <input type="checkbox" v-model="form.use_market_comp.value" @change="onFieldInput('use_market_comp')" /> 市场比较
                </label>
                <label style="font-size: 11px; display: flex; align-items: center; gap: 4px;">
                  <input type="checkbox" v-model="form.use_income_cap.value" @change="onFieldInput('use_income_cap')" /> 收益还原
                </label>
                <label style="font-size: 11px; display: flex; align-items: center; gap: 4px;">
                  <input type="checkbox" v-model="form.use_benchmark_corr.value" @change="onFieldInput('use_benchmark_corr')" /> 基准系数
                </label>
                <label style="font-size: 11px; display: flex; align-items: center; gap: 4px;">
                  <input type="checkbox" v-model="form.use_residual.value" @change="onFieldInput('use_residual')" /> 剩余法
                </label>
              </div>

              <!-- 5个评估方法比准单价输入框 -->
              <div class="form-item" v-if="form.use_cost_approx.value">
                <label class="form-label">成本逼近法单价（元/㎡）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.cost_approx_price.value" @input="onFieldInput('cost_approx_price')" 
                         :class="['field-input', getInputClass('cost_approx_price')]" />
                </div>
              </div>

              <div class="form-item" v-if="form.use_market_comp.value">
                <label class="form-label">市场比较法单价（元/㎡）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.market_comp_price.value" @input="onFieldInput('market_comp_price')" 
                         :class="['field-input', getInputClass('market_comp_price')]" />
                </div>
              </div>

              <div class="form-item" v-if="form.use_income_cap.value">
                <label class="form-label">收益还原法单价（元/㎡）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.income_cap_price.value" @input="onFieldInput('income_cap_price')" 
                         :class="['field-input', getInputClass('income_cap_price')]" />
                  <span v-if="showBadge('income_cap_price')" :class="['origin-badge', getBadgeClass('income_cap_price')]">
                    {{ getBadgeText('income_cap_price') }}
                  </span>
                </div>
              </div>

              <div class="form-item" v-if="form.use_benchmark_corr.value">
                <label class="form-label">基准地价系数修正法单价（元/㎡）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.benchmark_corr_price.value" @input="onFieldInput('benchmark_corr_price')" 
                         :class="['field-input', getInputClass('benchmark_corr_price')]" />
                  <span v-if="showBadge('benchmark_corr_price')" :class="['origin-badge', getBadgeClass('benchmark_corr_price')]">
                    {{ getBadgeText('benchmark_corr_price') }}
                  </span>
                </div>
              </div>

              <div class="form-item" v-if="form.use_residual.value">
                <label class="form-label">剩余法单价（元/㎡）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.residual_price.value" @input="onFieldInput('residual_price')" 
                         :class="['field-input', getInputClass('residual_price')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">基准地价超期限制年限（如 三）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.base_land_price_expire_limit.value" @input="onFieldInput('base_land_price_expire_limit')" 
                         :class="['field-input', getInputClass('base_land_price_expire_limit')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">确价加权逻辑（weight_logic_type）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.weight_logic_type.value" @input="onFieldInput('weight_logic_type')" 
                         :class="['field-input', getInputClass('weight_logic_type')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">主导测算方法（dominant_method_name）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.dominant_method_name.value" @input="onFieldInput('dominant_method_name')" 
                         :class="['field-input', getInputClass('dominant_method_name')]" />
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">规划条件批准机关（ planning_approval_authority ）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.planning_approval_authority.value" @input="onFieldInput('planning_approval_authority')" 
                         :class="['field-input', getInputClass('planning_approval_authority')]" />
                  <span v-if="showBadge('planning_approval_authority')" :class="['origin-badge', getBadgeClass('planning_approval_authority')]">
                    {{ getBadgeText('planning_approval_authority') }}
                  </span>
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">确价公式表达（formula_display_text）</label>
                <div class="input-wrapper">
                  <input type="text" v-model="form.formula_display_text.value" @input="onFieldInput('formula_display_text')" 
                         :class="['field-input', getInputClass('formula_display_text')]" />
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">方法适用性方案（land_level_type）</label>
                <div class="input-wrapper">
                  <select v-model="form.land_level_type.value" @change="onFieldInput('land_level_type')" class="field-input">
                    <option value="residential_level_3">住宅三级基准地价适用</option>
                    <option value="residential_level_2">住宅二级基准地价适用</option>
                    <option value="base_land_price_expired">基准地价超期停用</option>
                  </select>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">确价理由方案（method_combination_type）</label>
                <div class="input-wrapper">
                  <select v-model="form.method_combination_type.value" @change="onFieldInput('method_combination_type')" class="field-input">
                    <option value="residential_residual_only">住宅：剩余法唯一主导</option>
                    <option value="industrial_cost_and_market_average">工业：成本逼近 + 市场比较</option>
                    <option value="weight_average_method">收益还原 + 基准系数加权</option>
                    <option value="market_and_base_weight">市场比较 + 基准系数加权</option>
                    <option value="single_method_base">基准系数单一方法</option>
                  </select>
                </div>
              </div>

              <div class="form-item">
                <label class="form-label">基础设施方案（infrastructure_type）</label>
                <div class="input-wrapper">
                  <select v-model="form.infrastructure_type.value" @change="onFieldInput('infrastructure_type')" class="field-input">
                    <option value="five_通_residential">五通一平（住宅顺序）</option>
                    <option value="five_通_industrial">五通一平（工业顺序）</option>
                    <option value="three_通">三通一平</option>
                  </select>
                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label">采用方法理由阐述（weight_rationale_text）</label>
                <div class="input-wrapper">
