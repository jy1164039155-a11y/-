                </div>
              </div>

              <div class="form-item full-width">
                <label class="form-label" style="color: var(--accent); font-weight: 700;">📝 方案四：基础设施开发程度大段落（ infrastructure_detail ）</label>
                <div class="input-wrapper">
                  <textarea v-model="form.infrastructure_detail.value" @input="onFieldInput('infrastructure_detail')" 
                            rows="4" :class="['field-input', getInputClass('infrastructure_detail')]"
