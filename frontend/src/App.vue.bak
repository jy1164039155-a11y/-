  area_docs_desc_name: { value: '土地资产评估委托书、土地分户分摊面积明细表', origin: 'manual', is_dirty: false },
  room_detail_location: { value: '通道侗族自治县双江镇城南街皮革厂家属楼3栋4层404房', origin: 'manual', is_dirty: false },
  proof_doc_name: { value: '通道县房屋登记核发权证申请表', origin: 'manual', is_dirty: false },
  proof_doc_date: { value: '2002年12月30日', origin: 'manual', is_dirty: false },
  user_identity: { value: '公职人员', origin: 'manual', is_dirty: false },
  buy_year: { value: '2002年', origin: 'manual', is_dirty: false },
  buy_location_desc: { value: '通道县双江镇城南街皮革厂家属楼', origin: 'manual', is_dirty: false },
  registered_house_area: { value: '107.13', origin: 'manual', is_dirty: false },
  
  land_cert_name: { value: '', origin: 'manual', is_dirty: false },
  land_cert_no: { value: '', origin: 'manual', is_dirty: false },
  land_use_type: { value: '', origin: 'manual', is_dirty: false }
});

// 监听要素，自动更新 project_name
watch(
  () => [
    form.client_name.value, 
    form.transfer_purpose.value, 
    form.land_location.value, 
    form.land_plot_number.value,
    form.parcel_count.value,
    form.land_usage.value,
    form.project_name_suffix.value
  ],
  ([client, transfer, location, plot, parcel, usage, suffix]) => {
    const fullLocation = `${location || ''}${plot || ''}`;
    form.land_location_full.value = fullLocation;
    form.land_location_full.origin = 'manual';

    form.project_name.value = `${client || ''}${transfer || ''}涉及位于${fullLocation}的${parcel || '一宗'}${usage || ''}${suffix || ''}`;
    form.project_name.origin = 'manual';
  },
  { immediate: true }
);

onMounted(() => {
  regenerateOwnershipDraft(false);
});

// Toast 控制系统
const toasts = ref([]);
let toastId = 0;
const showToast = (text, type = 'success') => {
  const id = toastId++;
  toasts.value.push({ id, text, type });
  setTimeout(() => {
    toasts.value = toasts.value.filter(t => t.id !== id);
  }, 4000);
};

// 4. 视觉状态机辅助函数
const getInputClass = (key) => {
  const field = form[key];
  if (!field) return '';
  if (field.is_dirty) return '';
  if (field.origin === 'excel_imported') return 'origin-excel';
  if (field.origin === 'ocr_extracted') return 'origin-ocr';
  return '';
};

const showBadge = (key) => {
  const field = form[key];
  return field && field.origin !== 'manual' && !field.is_dirty;
};

const getBadgeClass = (key) => {
  const field = form[key];
  if (!field) return '';
  if (field.origin === 'excel_imported') return 'excel';
  if (field.origin === 'ocr_extracted') return 'ocr';
  return '';
};

const getBadgeText = (key) => {
  const field = form[key];
  if (!field) return '';
  if (field.origin === 'excel_imported') return '📊 测算表';
  if (field.origin === 'ocr_extracted') return '📷 证照识别';
  return '';
};

const applyExtractedFields = (extracted, origin = 'ocr_extracted') => {
  let matchCount = 0;
  Object.keys(extracted || {}).forEach(key => {
    const value = extracted[key];
    if (form[key] && value !== '' && value !== null && value !== undefined && value !== '______') {
      form[key].value = value;
      form[key].origin = origin;
      form[key].is_dirty = false;
      matchCount++;
    }
  });
  regenerateOwnershipDraft(false);
  return matchCount;
};

// 键盘敲击，主权瞬间秒级收归人工！背景变白，微章隐去！
const onFieldInput = (key) => {
  const field = form[key];
  if (field) {
    field.is_dirty = true;
    field.origin = 'manual';
  }
};

const buildPlotRatioDisplay = () => {
  const mode = form.plot_ratio_mode?.value || 'range';
  const value = String(form.plot_ratio?.value || '').trim();
  const min = String(form.plot_ratio_min?.value || '').trim();
  return mode === 'range' && min ? `${min}-${value}` : value;
};

const syncPlotRatioDisplay = (force = false) => {
  if (!form.plot_ratio_display) return;
  if (force || !form.plot_ratio_display.is_dirty) {
    form.plot_ratio_display.value = buildPlotRatioDisplay();
    form.plot_ratio_display.origin = form.plot_ratio.origin;
    form.plot_ratio_display.is_dirty = false;
  }
};

const onPlotRatioInput = (key) => {
  onFieldInput(key);
  syncPlotRatioDisplay(true);
};

const textValue = (key, fallback = '') => {
  const value = form[key]?.value;
  if (value === null || value === undefined) return fallback;
  const text = String(value).trim();
  return text && text !== '______' ? text : fallback;
};

const wrapDoc = (name, no = '', date = '') => {
  let docName = String(name || '').trim();
  if (!docName || docName === '______') return '';
  docName = docName.startsWith('《') && docName.endsWith('》') ? docName : `《${docName.replace(/[《》]/g, '')}》`;
  const extras = [no, date].map(v => String(v || '').trim()).filter(v => v && v !== '______');
  return extras.length ? `${docName}（${extras.join('，')}）` : docName;
};

const wrapDocList = (names) => String(names || '')
  .split(/[、,，;；\n]+/)
  .map(name => wrapDoc(name.trim()))
  .filter(Boolean)
  .join('、');

const inferAssetUseCategory = () => {
  const explicit = form.asset_use_category?.value;
  if (['residential', 'industrial', 'commercial', 'public', 'other'].includes(explicit)) return explicit;
  const usage = `${textValue('land_usage_short')}${textValue('land_usage')}${textValue('land_usage_full')}`;
  if (/住宅|居住|公寓/.test(usage)) return 'residential';
  if (/工业|工矿|仓储|物流|厂房/.test(usage)) return 'industrial';
  if (/商业|商服|商务|零售|餐饮|旅馆|娱乐|金融/.test(usage)) return 'commercial';
  if (/公共|机关|教育|医疗|文化|体育|交通|公用/.test(usage)) return 'public';
  return 'other';
};

const assetUseLabel = (category = inferAssetUseCategory()) => {
  if (category === 'other') {
    return textValue('asset_use_category_other') || textValue('land_usage_short') || textValue('land_usage') || '其他用途';
  }
  return {
    residential: '住宅',
    industrial: '工业',
    commercial: '商业服务业',
    public: '公共管理与公共服务'
  }[category] || '其他用途';
};

const supplyPhrase = (label) => label.endsWith('用地') ? `拟作为${label}供应` : `拟作为${label}用途国有建设用地供应`;

const normalizedOwnershipScenario = () => {
  const raw = form.ownership_scenario_type?.value || form.land_status_type?.value || 'new_grant';
  return raw === 'registered' ? 'registered_complete' : raw;
};

const ownershipContext = () => ({
  land_location: textValue('land_location_full') || textValue('land_location', '估价对象坐落'),
  land_area: textValue('land_area', '____'),
  building_area: textValue('building_area', '____'),
  land_user: textValue('land_user', '待确认权利人'),
  land_usage: textValue('land_usage') || textValue('land_usage_short', '设定用途'),
  land_usage_short: textValue('land_usage_short') || textValue('land_usage', '设定用途'),
  asset_use_label: assetUseLabel(),
  right_type: textValue('right_type', '国有出让'),
  registered_right_type: textValue('registered_right_type') || textValue('right_type', '国有划拨'),
  land_use_type: textValue('land_use_type') || textValue('registered_right_type') || textValue('right_type', '登记使用权类型'),
  valuation_condition_type: textValue('valuation_condition_type', '现状'),
  assumed_right_status: textValue('assumed_right_status', '无他项权利的完全权利条件'),
  actual_dev: textValue('land_development_actual', '宗地红线内外开发程度以委托方资料及现场勘查为准'),
  set_dev: textValue('land_development_set', '设定开发程度以本次地价定义为准'),
  boundary: textValue('land_boundary_desc', '四至界址以委托方提供资料及现场勘查结果为准'),
  room_location: textValue('room_detail_location') || textValue('land_location_full') || textValue('land_location', '估价对象坐落'),
  buy_year: textValue('buy_year'),
  buy_location: textValue('buy_location_desc'),
  user_identity: textValue('user_identity'),
  registered_house_area: textValue('registered_house_area') || textValue('building_area', '____')
});

const setGeneratedField = (key, value, force = false) => {
  const field = form[key];
  if (!field) return;
  const canUpdate = force || !field.is_dirty && (field.origin === 'generated' || !String(field.value || '').trim());
  if (canUpdate) {
    field.value = value;
    field.origin = 'generated';
    field.is_dirty = false;
  }
};

const regenerateOwnershipDraft = async (force = false) => {
  const edited = ['land_registration_desc', 'land_right_desc', 'land_use_status_desc']
    .some(key => form[key]?.is_dirty && String(form[key]?.value || '').trim());
  if (force && edited && !confirm('当前权属正文已有手工修改，是否覆盖为系统重新生成的草稿？')) {
    return;
  }
  
  const payload = {};
  Object.keys(form).forEach(key => {
    payload[key] = textValue(key);
  });
  
  try {
    const res = await fetch('http://127.0.0.1:8000/api/build-ownership-draft', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ data: payload })
    });
    if (!res.ok) throw new Error('生成草稿失败');
    const result = await res.json();
    if (result.status === 'success') {
      const drafts = result.data;
      if (drafts.ownership_scenario_type) form.ownership_scenario_type.value = drafts.ownership_scenario_type;
      if (drafts.ownership_scenario_type) form.land_status_type.value = drafts.ownership_scenario_type === 'registered_complete' ? 'registered' : drafts.ownership_scenario_type;
      if (drafts.asset_use_category) form.asset_use_category.value = drafts.asset_use_category;
      
      const keysToUpdate = ['land_registration_desc', 'land_right_desc', 'land_use_status_desc'];
      keysToUpdate.forEach(key => setGeneratedField(key, drafts[key], force));
      showToast('权属草稿已由后端智能引擎重新生成', 'success');
    }
  } catch (err) {
    showToast('调用后端草稿引擎失败: ' + err.message, 'error');
  }
};

const onOwnershipControlChange = (key) => {
  onFieldInput(key);
  regenerateOwnershipDraft(true);
};

// 5. 换肤控制 (支持冷色温浅色切换)
const toggleTheme = () => {
  isLightTheme.value = !isLightTheme.value;
  showToast(isLightTheme.value ? '☀️ 已切换为冷白高对比度模式' : '🌙 已切换为护眼暗黑模式', 'warning');
};

// ==============================================================================
// 📥 测算表拖拽解析
// ==============================================================================
const handleDragOver = () => {
  isDragging.value = true;
};

const handleDragLeave = () => {
  isDragging.value = false;
};

const handleFileDrop = async (e) => {
  isDragging.value = false;
  const files = e.dataTransfer.files;
  if (files.length === 0) return;
  
  const file = files[0];
  if (!file.name.endsWith('.xlsx')) {
    showToast('❌ 仅支持拖入 .xlsx 格式的测算表', 'error');
    return;
  }
  
  // 组装上传表单
  const formData = new FormData();
  formData.append('file', file);
  
  isLoading.value = true;
  loadingMessage.value = '正在一键安全解析 Excel 测算表...';
  
  try {
    const response = await fetch('http://127.0.0.1:8000/api/parse-excel', {
      method: 'POST',
      body: formData
    });
    
    if (!response.ok) {
      const err = await response.json();
      throw new Error(err.detail || '接口解析失败');
    }
    
    const res = await response.json();
    
    // 更新元数据
    excelMetadata.name = res.excel_name;
    excelMetadata.md5 = res.md5_checksum;
    
    // 自动触发回填，并打上 excel_imported 标签
    const back_data = res.data;
    Object.keys(back_data).forEach(key => {
      const incomingValue = back_data[key];
      if (form[key] && incomingValue !== '' && incomingValue !== null && incomingValue !== undefined && incomingValue !== '______') {
        form[key].value = incomingValue;
        form[key].origin = 'excel_imported';
        form[key].is_dirty = false;
      }
    });
    syncPlotRatioDisplay(true);
    regenerateOwnershipDraft(false);
    
    // 自动展开所有卡片以便审计回填数据
    collapsed.p1 = false;
    collapsed.p2 = false;
    collapsed.p3 = false;
    collapsed.p4 = false;
    
    showToast('🎉 Excel 测算表成功一键解析并回填！');
  } catch (error) {
    showToast(`❌ 解析失败: ${error.message}`, 'error');
  } finally {
    isLoading.value = false;
  }
};

// ==============================================================================
// 📷 证照 OCR 直贴提取
// ==============================================================================
const handleOcrExtract = async () => {
  if (!ocrRawText.value.trim()) {
    showToast('⚠ 请先粘贴待识别的原始文本', 'warning');
    return;
  }
  
  isLoading.value = true;
  loadingMessage.value = '正在调用离线高精度匹配引擎提取指标...';
  
  try {
    const response = await fetch('http://127.0.0.1:8000/api/ocr', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        raw_text: ocrRawText.value,
        attachment_type: ocrType.value
      })
    });
    
    if (!response.ok) {
      throw new Error('OCR 提取服务连接失败');
    }
    
    const res = await response.json();
    const matchCount = applyExtractedFields(res.data);
    
    if (matchCount > 0) {
      showToast(`🎉 离线引擎提取成功！共规整回填了 ${matchCount} 个证书指标。`);
      // 自动展开所有卡片以便审计回填数据
      collapsed.p1 = false;
      collapsed.p2 = false;
      collapsed.p3 = false;
      collapsed.p4 = false;
    } else {
      showToast('⚠ 提取成功但未能匹配到对应字段，请检查文本是否正确', 'warning');
    }
    
  } catch (error) {
    showToast(`❌ OCR 识别提取阶段失败: ${error.message}`, 'error');
  } finally {
    isLoading.value = false;
  }
};

const handleOcrFileUpload = async (event) => {
  const files = Array.from(event.target.files || []);
  if (!files.length) return;

  isLoading.value = true;
  loadingMessage.value = '正在读取附件文字层并提取指标...';

  let totalMatches = 0;
  const extractedTexts = [];
  const failures = [];

  try {
    for (const file of files) {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('attachment_type', ocrType.value);
      formData.append('min_text_chars', String(ocrMinTextChars.value ?? 80));

      const response = await fetch('http://127.0.0.1:8000/api/ocr-file', {
        method: 'POST',
        body: formData
      });

      if (!response.ok) {
        let message = '附件识别失败';
        try {
          const err = await response.json();
          message = err.detail || message;
        } catch (_) {}
        failures.push(`${file.name}: ${message}`);
        continue;
      }

      const res = await response.json();
      totalMatches += applyExtractedFields(res.data);
      if (res.text) {
        extractedTexts.push(`【${file.name}｜${res.extraction_method}】\n${res.text}`);
      }
    }

    if (extractedTexts.length) {
      ocrRawText.value = extractedTexts.join('\n\n---\n\n');
    }

    if (totalMatches > 0) {
      collapsed.p1 = false;
      collapsed.p2 = false;
      collapsed.p3 = false;
      collapsed.p4 = false;
      showToast(`🎉 附件识别完成，已回填 ${totalMatches} 个字段。`);
    } else if (extractedTexts.length) {
      showToast('⚠ 附件已提取文字，但未匹配到表单字段，请检查附件类型选择。', 'warning');
    }

    if (failures.length) {
      showToast(`⚠ 部分附件未能识别：${failures[0]}`, 'warning');
    }
  } catch (error) {
    showToast(`❌ 附件识别失败: ${error.message}`, 'error');
  } finally {
    isLoading.value = false;
    event.target.value = '';
  }
};

// ==============================================================================
// 📄 高保真 A4 渲染与即用即销预览
// ==============================================================================
const handleRenderReport = async () => {
  isLoading.value = true;
  loadingMessage.value = '正在物理渲染并转换为高保真 A4 PDF 预览...';
  
  // 拼装扁平 JSON 数据
  const renderData = {};
  Object.keys(form).forEach(key => {
    renderData[key] = form[key].value;
  });
  if (!renderData['plot_ratio_display']) {
    renderData['plot_ratio_display'] = buildPlotRatioDisplay();
  }
  
  // 加上 Excel 指纹和归档指令
  renderData['excel_name'] = excelMetadata.name || '桌面端手工微调填报';
  renderData['md5_checksum'] = excelMetadata.md5 || 'MANUAL_VER_NO_CHECKSUM';
  renderData['archive_to_result'] = true; // 渲染时顺便归档一份正式 word 文件到 03_Result
  
  try {
    const response = await fetch('http://127.0.0.1:8000/api/render-report', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(renderData)
    });
    
    if (!response.ok) {
      const err = await response.json();
      throw new Error(err.detail || '渲染引擎响应失败');
    }
    
    // 获取 Blob 流并建立本地临时 blob URL
    const blob = await response.blob();
    if (pdfUrl.value) {
      URL.revokeObjectURL(pdfUrl.value); // 回收以前的 blob 内存
    }
    
    // 核心物理分流：智能检查 Blob 类型以确定展示模式
    if (blob.type === 'application/pdf') {
      pdfUrlType.value = 'pdf';
      pdfUrl.value = URL.createObjectURL(blob);
      showToast('🎉 A4 高保真报告极速渲染成功！PDF 预览已实时刷新！');
    } else {
      pdfUrlType.value = 'docx';
      pdfUrl.value = URL.createObjectURL(blob);
      
      // 物理触发自动极速下载，对齐用户的高效操作
      const link = document.createElement('a');
      link.href = pdfUrl.value;
      
      // 采用清晰的项目简名命名下载文件，后端归档更严密
      const prjName = form.land_location.value || '自动生成的估价报告';
      link.download = `${prjName.replace(/[\\/:*?"<>|]/g, '_')}_高保真 Word 报告_${new Date().getTime()}.docx`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      
      showToast('🎉 本地另存为 PDF 接口挂起，平台已自愈降级，高保真 Word 报告已为您自动下载！', 'warning');
    }
  } catch (error) {
    showToast(`❌ 高保真 A4 渲染阶段失败: ${error.message}`, 'error');
  } finally {
    isLoading.value = false;
  }
};
</script>

